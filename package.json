  "scripts": {
    "test:chromium": "cross-env BROWSER=chromium cucumber-js --profile chromium",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js --profile firefox",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js --profile webkit",
    "test": "concurrently --kill-others-on-fail \"npm run test:chromium\" \"npm run test:firefox\" \"npm run test:webkit\"",
    "report": "node generate-report.js",
    "lint": "eslint ."
  },
